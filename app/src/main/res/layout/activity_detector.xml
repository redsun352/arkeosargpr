<?xml version="1.0" encoding="utf-8"?>
<ScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background_deep">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/detector_title"
            android:textColor="@color/signal_amber"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp" />

        <TextView
            android:id="@+id/statusText"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginBottom="16dp" />

        <!-- Spectrum bar (top strip, matches the reference app's frequency-bar look) -->
        <com.arkeosar.groundscan.ui.LiveSpectrumBarView
            android:id="@+id/spectrumBarView"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:background="@color/surface_panel"
            android:layout_marginBottom="5dp" />

        <!-- Line graph -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="120dp"
            android:background="@color/surface_panel"
            android:layout_marginBottom="5dp">

            <com.arkeosar.groundscan.ui.LiveLineGraphView
                android:id="@+id/lineGraphView"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />

            <TextView
                android:id="@+id/liveValueText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="top|end"
                android:padding="6dp"
                android:textColor="@color/text_primary"
                android:textSize="18sp"
                android:fontFamily="monospace" />
        </FrameLayout>

        <!-- Live heatmap, color/size driven by the selected function -->
        <com.arkeosar.groundscan.ui.LiveHeatmapView
            android:id="@+id/heatmapView"
            android:layout_width="match_parent"
            android:layout_height="180dp"
            android:background="@color/surface_panel"
            android:layout_marginBottom="8dp" />

        <!-- Single-value bar, kept alongside the heatmap as a compact numeric gauge -->
        <com.arkeosar.groundscan.ui.LiveColumnGraphView
            android:id="@+id/columnGraphView"
            android:layout_width="match_parent"
            android:layout_height="24dp"
            android:layout_marginBottom="16dp" />

        <!-- Function picker: which axis combination drives the value above -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/detector_function_label"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <Spinner
            android:id="@+id/spinnerFunction"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginBottom="16dp" />

        <!-- Gain control -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/detector_gain_label"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <com.google.android.material.slider.Slider
            android:id="@+id/gainSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <com.google.android.material.switchmaterial.SwitchMaterial
            android:id="@+id/preserveSignSwitch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/detector_preserve_sign_label"
            android:textColor="@color/text_secondary"
            android:layout_marginBottom="16dp" />

        <!-- Threshold / noise floor control -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/detector_threshold_label"
            android:textColor="@color/text_primary"
            android:textSize="14sp" />

        <com.google.android.material.slider.Slider
            android:id="@+id/thresholdSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/buttonMeasureNoise"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/detector_measure_noise_button"
            android:layout_marginTop="8dp" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/detector_frequency_label"
            android:textColor="@color/text_primary"
            android:textSize="14sp"
            android:layout_marginTop="20dp" />

        <com.arkeosar.groundscan.ui.LiveLineGraphView
            android:id="@+id/frequencyGraphView"
            android:layout_width="match_parent"
            android:layout_height="100dp"
            android:background="@color/surface_panel"
            android:layout_marginTop="4dp" />

    </LinearLayout>
</ScrollView>
